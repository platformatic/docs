{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "docs\\.platformatic\\.dev"
        }
      ],
      "destination": "https://platformatic.dev/docs/Overview",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/schemas/v:version/:service",
      "destination": "https://raw.githubusercontent.com/platformatic/schemas/main/v:version/:service"
    }
  ]
}